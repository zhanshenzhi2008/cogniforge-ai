# =====================================================================
# cogniforge-ai 生产环境变量
# cp .env.example .env  # 然后填真实值
# =====================================================================

# ─── 镜像命名空间（CD 自动注入，也可手动覆盖）─────────────
IMAGE_NAMESPACE=zhanshenzhi2008

# ─── 数据库（公用 ../envs/db.env，必须与 .env.db 一致）────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_secure_random_password_at_least_16_chars
POSTGRES_DB=cogniforge

# ─── 服务日志 ────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── LLM API Keys 已移到 ../envs/llm.env（共享）────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
