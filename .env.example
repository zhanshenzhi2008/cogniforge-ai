# Cogniforge AI Service Environment Variables

# LLM Providers
export OPENAI_API_KEY=sk-...
export ANTHROPIC_API_KEY=sk-ant-...

# Default LLM Model
export DEFAULT_MODEL=gpt-4o
export DEFAULT_TEMPERATURE=0.7
export DEFAULT_MAX_TOKENS=4096

# RAG / Embedding
export EMBEDDER_TYPE=openai  # or 'local' for sentence-transformers
export CHUNK_SIZE=512
export CHUNK_OVERLAP=50

# PostgreSQL / pgvector
export POSTGRES_HOST=localhost
export POSTGRES_PORT=5432
export POSTGRES_DB=cogniforge
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres

# Redis (optional, for distributed memory)
export REDIS_HOST=localhost
export REDIS_PORT=6379
export REDIS_DB=0

# Server
export HOST=0.0.0.0
export PORT=8086
export LOG_LEVEL=INFO
